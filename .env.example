# Copy this to .env and adjust values.
# .env is ignored by git.

# Traefik BasicAuth users (htpasswd format, user:hash)
# Example:
# IMPORTANT: escape each "$" as "$$" for docker compose interpolation.
# BASIC_AUTH_USERS=dschib:$$2b$$12$$replace_with_your_bcrypt_hash
BASIC_AUTH_USERS=

# Optional overrides (compose already sets defaults)
ADDR=:8085
DATA_FILE=/app/data/license-db.json
UPDATES_DIR=/app/updates

# Optional: token required for /api/updates/upload and /api/updates/files
# (recommended when exposing admin APIs via HTTPS)
UPDATES_UPLOAD_TOKEN=

# Optional max upload size for updater assets (MB)
UPDATES_MAX_UPLOAD_MB=2048

# Shared secret for POST /api/keys/consume (Next.js server → license backend).
# When set, requests must include header: x-liveforge-consume-secret: <value>
# Leave empty only for local dev.
CONSUME_SECRET=
